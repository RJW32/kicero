# SendGrid Contact Form Configuration
SENDGRID_API_KEY="SG.xxxxx"
CONTACT_TO_EMAIL="info@kicero.co.uk"
CONTACT_FROM_EMAIL="noreply@kicero.co.uk"
CONTACT_FROM_NAME="Kicero Website Questionnaire"
# Direct-to-R2 uploads (required in production for large files / videos). After creating an
# R2 API token, add the same values in the Workers dashboard (or wrangler secret / vars).
# R2 bucket CORS must allow PUT from https://kicero.co.uk and http://localhost:3000 (dev).
R2_PUBLIC_BASE="https://uploads.kicero.co.uk"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="kicero-questionnaire-uploads"
LOCAL_UPLOAD_DIR="uploads"

# Analytics (optional — leave blank to disable)
# Privacy-friendly Plausible analytics — set this to your live domain
VITE_PLAUSIBLE_DOMAIN=""
# Override script URL if you self-host Plausible
VITE_PLAUSIBLE_SCRIPT="https://plausible.io/js/script.js"
# Microsoft Clarity (free heatmaps + session recordings)
VITE_CLARITY_PROJECT_ID=""

# Show the development disclaimer banner on the homepage
# Set to "true" while the site is still considered a work in progress
VITE_SHOW_DEV_DISCLAIMER="false"
