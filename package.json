{
  "name": "kicero",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx server.ts",
    "dev:full": "tsx server.ts & vite --port=3000 --host=0.0.0.0",
    "cf:login": "wrangler login",
    "cf:secret:sendgrid": "wrangler secret put SENDGRID_API_KEY --name kicero",
    "cf:deploy": "npm run build && wrangler deploy",
    "build": "vite build && npm run prerender",
    "build:spa": "vite build",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "@unhead/react": "^3.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@sparticuz/chromium": "^148.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "puppeteer": "^24.42.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wrangler": "^4.87.0"
  }
}
